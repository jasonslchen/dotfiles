#!/bin/zsh

zshrc() {
    echo "Linking zshrc"
    cat .zshrc > $HOME/.zshrc
}

# change time zone to match LA local time (Linux only)
if [[ "$(uname)" != "Darwin" ]]; then
    sudo ln -fs /usr/share/zoneinfo/America/Los_Angeles /etc/localtime
    sudo dpkg-reconfigure --frontend noninteractive tzdata
fi

zshrc

# ZSH {
# Change to zsh
if [[ "$SHELL" != "$(which zsh)" ]]; then
		sudo chsh -s $(which zsh)
fi

function link_files() {
  if [[ ! $(pwd) -ef $HOME ]]; then
    # Git link
    rm -f ~/.gitconfig
    ln -s $(pwd)/.gitconfig ~/.gitconfig
  fi
}

echo "Symlinking dotfiles"
link_files
echo "Finish symlinking dotfiles"

# Skills (Copilot CLI / Claude Code)
# Returns 0 (available) for skills that should always link;
# returns non-zero to skip a skill that depends on a local-only tool.
is_skill_available() {
    case "$1" in
        codeflow)
            [[ -x "$HOME/projects/codeflow/.venv/bin/codeflow" ]]
            ;;
        *)
            return 0
            ;;
    esac
}

link_skill_dir() {
    emulate -L zsh
    setopt local_options null_glob
    local src="$1" dst="$2"
    [[ -d "$src" ]] || return 0
    mkdir -p "$dst"
    local skill_path name target backup
    for skill_path in "$src"/*/; do
        name=$(basename "$skill_path")
        if ! is_skill_available "$name"; then
            echo "  skip $name (local-only skill not available on this machine)"
            continue
        fi
        target="$dst/$name"
        if [[ -L "$target" ]]; then
            rm "$target"
        elif [[ -e "$target" ]]; then
            backup="$target.bak.$(date +%Y%m%d%H%M%S)"
            echo "  backing up existing $target -> $backup"
            mv "$target" "$backup"
        fi
        ln -s "${skill_path%/}" "$target"
        echo "  linked $name -> $target"
    done
}

echo "Linking agent skills"
link_skill_dir "$(pwd)/.copilot/skills" "$HOME/.copilot/skills"
link_skill_dir "$(pwd)/.claude/skills"  "$HOME/.claude/skills"
echo "Finish linking agent skills"

# Copy our Copilot instruction files additively into the device's instructions
# folder. We copy (not symlink) so a device's own instructions are never
# replaced, and we create the folder if it doesn't exist. Each of our files is
# uniquely named; an existing, differing file with the same name is backed up
# before being refreshed.
copy_instructions() {
    emulate -L zsh
    setopt local_options null_glob
    local src_dir="$1" dst_dir="$2"
    [[ -d "$src_dir" ]] || return 0
    mkdir -p "$dst_dir"
    local f name dst backup
    for f in "$src_dir"/*.instructions.md; do
        name=$(basename "$f")
        dst="$dst_dir/$name"
        if [[ ! -e "$dst" ]]; then
            cp "$f" "$dst"
            echo "  added $name"
        elif cmp -s "$f" "$dst"; then
            echo "  up to date $name"
        else
            backup="$dst.bak.$(date +%Y%m%d%H%M%S)"
            echo "  backing up existing $dst -> $backup"
            mv "$dst" "$backup"
            cp "$f" "$dst"
            echo "  updated $name"
        fi
    done
}

# Remove the legacy global instructions symlink we used to create. Its content
# now lives in the instructions/ folder as an always-apply file. We only remove
# our own symlink into this repo, never a device's real copilot-instructions.md.
old_global="$HOME/.copilot/copilot-instructions.md"
if [[ -L "$old_global" && "$(readlink "$old_global")" == *"/dotfiles/.copilot/copilot-instructions.md" ]]; then
    rm "$old_global"
    echo "Removed legacy global instructions symlink $old_global"
fi

echo "Adding agent instructions"
copy_instructions "$(pwd)/.copilot/instructions" "$HOME/.copilot/instructions"
echo "Finish adding agent instructions"

# make directly highlighting readable - needs to be after zshrc line
# colors: https://askubuntu.com/questions/466198/how-do-i-change-the-color-for-directories-with-ls-in-the-console
# configuring colors: https://www.bigsoft.co.uk/blog/2008/04/11/configuring-ls_colors
echo "" >> ~/.zshrc
echo "# remove ls and directory completion highlight color" >> ~/.zshrc
echo "_ls_colors=':ow=01;33'" >> ~/.zshrc
echo 'zstyle ":completion:*:default" list-colors "${(s.:.)_ls_colors}"' >> ~/.zshrc
echo 'LS_COLORS+=$_ls_colors' >> ~/.zshrc

# Install GitHub Copilot CLI
# Docs: https://docs.github.com/copilot/how-tos/set-up/install-copilot-cli
install_copilot_cli() {
    if command -v copilot >/dev/null 2>&1; then
        echo "  copilot already installed ($(copilot --version 2>/dev/null | head -1))"
    elif [[ "$(uname)" == "Darwin" ]]; then
        brew install --cask copilot-cli
    else
        local installer
        installer=$(mktemp "${TMPDIR:-/tmp}/copilot-install.XXXXXX") || return 1
        if ! curl -fsSL https://gh.io/copilot-install -o "$installer" ||
            ! bash "$installer"; then
            rm -f "$installer"
            return 1
        fi
        rm -f "$installer"
        export PATH="$HOME/.local/bin:$PATH"
    fi
}

echo "Installing GitHub Copilot CLI"
if install_copilot_cli; then
    echo "Finish installing GitHub Copilot CLI"
else
    echo "  failed to install GitHub Copilot CLI; continuing setup" >&2
fi

# Log in to GitHub Copilot CLI as the current user.
# Copilot checks credentials in this order: environment, system keychain,
# plaintext fallback, then GitHub CLI.
copilot_token_supported() {
    [[ "$1" == gho_* || "$1" == ghu_* || "$1" == github_pat_* ]]
}

copilot_authenticated() {
    local token="${COPILOT_GITHUB_TOKEN:-${GH_TOKEN:-${GITHUB_TOKEN:-}}}"
    if [[ -n "$token" ]]; then
        copilot_token_supported "$token"
        return
    fi
    if [[ "$(uname)" == "Darwin" ]]; then
        security find-generic-password -s copilot-cli >/dev/null 2>&1 && return 0
    elif command -v secret-tool >/dev/null 2>&1; then
        secret-tool search service copilot-cli >/dev/null 2>&1 && return 0
    fi
    [[ -r "$HOME/.copilot/config.json" ]] &&
        grep -Eq 'gho_[[:alnum:]_]+|ghu_[[:alnum:]_]+|github_pat_[[:alnum:]_]+' \
            "$HOME/.copilot/config.json" && return 0
    command -v gh >/dev/null 2>&1 || return 1
    token=$(gh auth token 2>/dev/null) || return 1
    copilot_token_supported "$token"
}

echo "Logging in to GitHub Copilot CLI"
if ! command -v copilot >/dev/null 2>&1; then
    echo "  copilot not found on PATH; skipping login"
elif copilot_authenticated; then
    echo "  already authenticated; skipping login"
elif [[ -t 0 ]]; then
    copilot login
else
    echo "  no TTY available; run 'copilot login' manually to authenticate"
fi
echo "Finish logging in to GitHub Copilot CLI"

# Install lazygit
echo "Installing lazygit"
if [[ "$(uname)" == "Darwin" ]]; then
    brew install lazygit
else
    LAZYGIT_VERSION=$(curl -s "https://api.github.com/repos/jesseduffield/lazygit/releases/latest" | grep -Po '"tag_name": "v\K[^"]*')
    curl -Lo lazygit.tar.gz "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${LAZYGIT_VERSION}_Linux_x86_64.tar.gz"
    tar xf lazygit.tar.gz lazygit
    sudo install lazygit /usr/local/bin
    rm lazygit lazygit.tar.gz
fi
echo "Finish installing lazygit"